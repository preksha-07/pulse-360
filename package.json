{
  "name": "pulse360",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspace=client && mkdir -p dist && cp -R client/dist/. dist",
    "test": "npm run test --workspaces",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
